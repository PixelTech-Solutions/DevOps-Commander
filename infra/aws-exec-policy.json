{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "DevEc2PowerOnly",
      "Effect": "Allow",
      "Action": [
        "ec2:StartInstances",
        "ec2:StopInstances",
        "ec2:RebootInstances"
      ],
      "Resource": [
        "arn:aws:ec2:us-east-1:678191059773:instance/i-079e547101bf680a2",
        "arn:aws:ec2:us-east-1:678191059773:instance/i-083032133276a6d9f"
      ]
    },
    {
      "Sid": "DescribeForStatus",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:DescribeInstanceStatus"
      ],
      "Resource": "*"
    }
  ]
}
